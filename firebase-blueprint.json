{
  "entities": {
    "Notice": {
      "title": "Notice",
      "description": "공지사항 게시글 엔티티",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "공지사항 제목"
        },
        "content": {
          "type": "string",
          "description": "공지사항 내용"
        },
        "author": {
          "type": "string",
          "description": "작성자"
        },
        "date": {
          "type": "string",
          "description": "작성일 (YYYY-MM-DD)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "생성 일시"
        }
      },
      "required": ["title", "content", "author", "date", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "앱 설정 (관리자 비밀번호 등)",
      "type": "object",
      "properties": {
        "adminPassword": {
          "type": "string",
          "description": "관리자 비밀번호"
        }
      },
      "required": ["adminPassword"]
    }
  },
  "firestore": {
    "notices": {
      "schema": "Notice",
      "description": "공지사항 컬렉션"
    },
    "settings": {
      "schema": "Settings",
      "description": "설정 컬렉션"
    }
  }
}
